{% extends "_layouts/cp.twig" %}
{% set title = "TryHackMe"|t('plugin-handle') %}
{% set userData = craft.tryhackme.userData %}
{% set tabs = {
  dashboard: {
    label: 'Dashboard'|t('plugin-handle'),
    url: '/admin/tryhackme/dashboard',
  },
  badges: {
    label: 'Badges'|t('plugin-handle'),
    url: '/admin/tryhackme/badges',
  },
  leaderboardCountry: {
    label: userData.country ,
    url: '/admin/tryhackme/leaderboard-country',
  },
} %}
{% set selectedTab = 'badges' %}

{% block content %}
    <div class="flex items-center justify-between mb-3">
        <h1>{{ 'Earned badges'|t('plugin-handle') }} <span class="light">({{ userData.earnedBadges }})</span></h1>
    </div>
    <div style="display:flex; flex-direction:column; gap:8px;">
        {% set badges = userData.badges|sort %}
        {% for badge in badges %}
            {% if badge.rarityTier == 'legendary' %}
                {% set rarityColor = '#f5a623' %}{% set rarityBg = '#fef6e4' %}
            {% elseif badge.rarityTier == 'epic' %}
                {% set rarityColor = '#9b59b6' %}{% set rarityBg = '#f5edfb' %}
            {% elseif badge.rarityTier == 'rare' %}
                {% set rarityColor = '#27ae60' %}{% set rarityBg = '#e4f7ed' %}
            {% else %}
                {% set rarityColor = '#3498db' %}{% set rarityBg = '#e8f4fd' %}
            {% endif %}
            <div style="background:#fff; border-radius:6px; padding:12px 16px; display:flex; align-items:center; gap:16px; box-shadow:0 1px 3px rgba(0,0,0,.08);">
                <img src="{{ badge.image }}" alt="{{ badge.title }}" style="width:64px; height:64px; object-fit:contain; flex-shrink:0;">
                <div style="flex:1;">
                    <div style="font-weight:700; font-size:13px; line-height:1.3;">{{ badge.title }}</div>
                    <div style="font-size:11px; color:var(--medium-text-color); line-height:1.4; margin-top:2px;">{{ badge.description }}</div>
                    <span style="display:inline-block; margin-top:6px; font-size:11px; font-weight:600; color:{{ rarityColor }}; background:{{ rarityBg }}; border-radius:20px; padding:2px 10px;">
                        {{ badge.rarityTier|capitalize }}: {{ badge.rarityPercent }}%
                    </span>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
